{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "plugin": [
    // "superpowers@git+https://github.com/obra/superpowers.git"
  ],

  "command": {
    "debug": {
      "template": "Run the tests and fix any failing logic. Use terminal commands to verify.",
      "model": "{{ opencode_plan_model }}",
      "description": "Deep debug"
    }
  },
  
  // Environment setup
  "shell": "zsh",
  "logLevel": "INFO",
  "snapshot": true,

  // Server settings
  "server": {
    "hostname": "0.0.0.0",
    "mdns": false,
    "port": 3000
  },

  // Ignored directories for file watcher
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.terraform/**",
      "**/dist/**",
      "**/build/**",
      "**/.cache/**",
      "**/.venv/**"
    ]
  },

  // Agent execution permissions
  "permission": {
    // "read": "allow",
    // "edit": "allow",
    // "task": "ask",
    // "bash": {
    //   "*": "ask",
    //   "ls": "allow",
    //   "ls *": "allow",
    //   "cat *": "allow",
    //   "pwd": "allow",
    //   "tree": "allow",
    //   "tree *": "allow",
    //   "grep *": "allow",
    //   "rg *": "allow",
    //   "find *": "allow"
    // }
  },

  // Developer tools and MCP servers
  "formatter": true,
  "lsp": true,
  "mcp": {
  },

  // Context and token memory management
  "compaction": {
    "auto": true,
    "prune": false,
    "tail_turns": 2
  },
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 51200
  },

  // Image attachment settings
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000
    }
  },

  // Providers & model variants configuration
  "provider": {
    "{{ opencode_provider_name }}": {
      "models": {
        "{{ opencode_plan_model }}": {
          "variants": {
            "plan": {
              "temperature": 0.1,
              "reasoningEffort": "high"
            }
          }
        },
        "{{ opencode_build_model }}": {
          "variants": {
            "build": {
              "temperature": 0.2
            }
          }
        },
        "{{ opencode_general_model }}": {
          "variants": {
            "general": {
              "temperature": 0.6
            }
          }
        }
      }
    }
  },

  // Agent role assignments mappings
  "agent": {
    "plan": {
      "model": "{{ opencode_provider_name }}/{{ opencode_plan_model }}",
      "variant": "plan",
      "mode": "primary",
      "description": "Architect agent for structural planning."
    },
    "build": {
      "model": "{{ opencode_provider_name }}/{{ opencode_build_model }}",
      "variant": "build",
      "mode": "primary",
      "description": "Build agent for active development."
    },
    "general": {
      "model": "{{ opencode_provider_name }}/{{ opencode_general_model }}",
      "variant": "general",
      "mode": "primary",
      "description": "General purpose chat agent."
    }
  },
  
  "default_agent": "plan"
}
